{
    "name": "@yamachu/n8n-nodes-mcp-client-for-slack",
    "version": "0.1.1",
    "description": "n8n nodes for MCP Client for Slack MCP Server",
    "license": "MIT",
    "homepage": "https://github.com/yamachu/n8n-nodes-mcp-client-for-slack#readme",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "yamachu",
        "email": "yamachu.dev@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yamachu/n8n-nodes-mcp-client-for-slack.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": false,
        "credentials": [
            "dist/credentials/McpForSlackOAuth2Api.credentials.js"
        ],
        "nodes": [
            "dist/nodes/McpClientForSlack/McpClientForSlack.node.js"
        ]
    },
    "devDependencies": {
        "@langchain/core": "*",
        "@n8n/json-schema-to-zod": "*",
        "@n8n/node-cli": "*",
        "@types/json-schema": "7.0.15",
        "eslint": "9.39.4",
        "prettier": "3.8.1",
        "release-it": "19.2.4",
        "typescript": "5.9.3",
        "zod": "^3"
    },
    "peerDependencies": {
        "@langchain/core": "*",
        "@n8n/json-schema-to-zod": "*",
        "n8n-workflow": "*",
        "zod": "^3"
    }
}
